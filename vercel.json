{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "toms.mdmarketinsights.com" }],
      "destination": "/toms-course.html"
    },
    {
      "source": "/toms",
      "destination": "/toms-course.html"
    },
    {
      "source": "/client",
      "destination": "/client.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/skillsite",
      "destination": "/skillsite.html"
    },
    {
      "source": "/thank-you",
      "destination": "/thank-you.html"
    }
  ]
}
